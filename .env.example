# ═══════════════════════════════════════════════════
#  方言互动后端 配置文件
# ═══════════════════════════════════════════════════

# ── 阿里云 DashScope (通义千问) ─── 主 AI 服务
# 获取: https://dashscope.console.aliyun.com/apiKey
# qwen3-omni-flash 同时返回文字和方言语音，是本项目的主引擎
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_OMNI_MODEL=qwen3-omni-flash
QWEN_TTS_MODEL=qwen3-omni-flash

# ── DeepSeek API ── 备用（已暂时停用）
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── 讯飞开放平台 ──
# 获取: https://console.xfyun.cn/ → 我的应用
XFYUN_APPID=your_appid_here
XFYUN_API_KEY=your_api_key_here
XFYUN_API_SECRET=your_api_secret_here

# ── 服务配置 ──
HOST=0.0.0.0
PORT=8000

# 开发模式: 生产环境应改为 false
DEV_MODE=false

# 数据库路径
DATABASE_URL=sqlite:///./fangyan.db

# 音频缓存目录（TTS 生成的 mp3 文件存这里）
AUDIO_CACHE_DIR=./audio_cache
